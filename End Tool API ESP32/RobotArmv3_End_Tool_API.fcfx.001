				</variable>
				<variable public='0' >
					<def class_type='variable' name='RegAdc0Raw_H' type='u8' description='Register 16: ADC0 raw high byte' isconst='0' isHidden='0' isinit='1' usrinit='0' setinit='0' />
				</variable>
			</variables>
			<macros >
				<macro >
					<flowline name='RefreshRegisterArrayFromVariables' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='calculation' title='Copy identity, status and PWM values into register array' >
							<exp exp='Registers[0] = RegProtocolVersion' />
							<exp exp='Registers[1] = RegFirmwareMajor' />
							<exp exp='Registers[2] = RegFirmwareMinor' />
							<exp exp='Registers[3] = RegToolTypeId' />
							<exp exp='Registers[4] = RegStatusFlags' />
							<exp exp='Registers[5] = RegPwm1Duty' />
							<exp exp='Registers[6] = RegPwm2Duty' />
							<exp exp='Registers[7] = RegPwmControl' />
						</command>
						<command class_type='calculation' title='Copy current measurement bytes into register array' >
							<exp exp='Registers[11] = RegCurrent1mA_L' />
							<exp exp='Registers[12] = RegCurrent1mA_H' />
							<exp exp='Registers[13] = RegCurrent2mA_L' />
							<exp exp='Registers[14] = RegCurrent2mA_H' />
							<exp exp='Registers[15] = RegCurrent3mA_L' />
							<exp exp='Registers[16] = RegCurrent3mA_H' />
						</command>
						<command class_type='calculation' title='Copy ADC telemetry bytes into register array' >
							<exp exp='Registers[17] = RegAdc0Raw_L' />
							<exp exp='Registers[18] = RegAdc0Raw_H' />
							<exp exp='Registers[19] = RegAdc1Raw_L' />
							<exp exp='Registers[20] = RegAdc1Raw_H' />
							<exp exp='Registers[21] = RegAdc0mV_L' />
							<exp exp='Registers[22] = RegAdc0mV_H' />
							<exp exp='Registers[23] = RegAdc1mV_L' />
							<exp exp='Registers[24] = RegAdc1mV_H' />
						</command>
						<command class_type='calculation' title='Copy hobby servo registers (addresses 48-56)' >
							<exp exp='Registers[48] = RegServoEnable' />
							<exp exp='Registers[49] = RegServoPosition8bit' />
							<exp exp='Registers[50] = RegServoAngleDeg' />
							<exp exp='Registers[51] = RegServoPulseMin_L' />
							<exp exp='Registers[52] = RegServoPulseMin_H' />
							<exp exp='Registers[53] = RegServoPulseMax_L' />
							<exp exp='Registers[54] = RegServoPulseMax_H' />
							<exp exp='Registers[55] = RegServoPosition8bit' />
							<exp exp='Registers[56] = RegServoAngleDeg' />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='SendStatusPacketWithMultiReadData' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='calculation' title='Prepare multi-byte READ response header' >
							<exp exp='TxLength = LastDataLength + 2' />
							<exp exp='TxError = 0' />
							<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
						</command>
						<command class_type='call' title='TX Header 1' component='UART_ServoBus' macro='SendChar' >
							<argument exp='255' />
						</command>
						<command class_type='call' title='TX Header 2' component='UART_ServoBus' macro='SendChar' >
							<argument exp='255' />
						</command>
						<command class_type='call' title='TX ID' component='UART_ServoBus' macro='SendChar' >
							<argument exp='BusDeviceID' />
						</command>
						<command class_type='call' title='TX LENGTH' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxLength' />
						</command>
						<command class_type='call' title='TX ERROR' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxError' />
						</command>
						<command class_type='calculation' title='Start at first register byte' >
							<exp exp='CommsByteIndex = 0' />
						</command>
						<command class_type='loop' title='Send each requested register byte' type='0' exp='CommsByteIndex &lt; LastDataLength' for1='' for2='' for3='' >
							<flowline >
								<command class_type='decision' title='Source address is inside register map' exp='(LastAddress + CommsByteIndex) &lt; 64' swap='0' >
									<flowline >
										<command class_type='calculation' title='Read register byte for TX' >
											<exp exp='TxDataByte = Registers[LastAddress + CommsByteIndex]' />
										</command>
									</flowline>
									<flowline >
										<command class_type='calculation' title='Out of range returns zero' >
											<exp exp='TxDataByte = 0' />
										</command>
									</flowline>
								</command>
								<command class_type='calculation' title='Add data byte to checksum' >
									<exp exp='TxChecksumSum = TxChecksumSum + TxDataByte' />
								</command>
								<command class_type='call' title='TX DATA BYTE' component='UART_ServoBus' macro='SendChar' >
									<argument exp='TxDataByte' />
								</command>
								<command class_type='calculation' title='Next byte' >
									<exp exp='CommsByteIndex = CommsByteIndex + 1' />
								</command>
							</flowline>
						</command>
						<command class_type='calculation' title='Finalize checksum' >
							<exp exp='TxChecksumSum = ~TxChecksumSum' />
							<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
						</command>
						<command class_type='call' title='TX CHECKSUM' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxChecksumSum' />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='UpdateAdcTelemetry' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='comment' title='' comment='Refresh local ADC telemetry values each loop' textarea='12,0,12,0' />
						<command class_type='decision' title='Decision' exp='AdcChannel &amp; 0x01' swap='0' >
							<flowline >
								<command class_type='call' title='Read ADC1 raw value (0-4095)' component='ADC1' macro='GetInt' >
									<return exp='Adc1Raw' />
								</command>
								<command class_type='decision' title='Clamp ADC1 raw to max count' exp='Adc1Raw &gt; AdcMaxCounts' swap='0' >
									<flowline >
										<command class_type='calculation' title='Force ADC1 raw into valid range' >
											<exp exp='Adc1Raw = AdcMaxCounts' />
										</command>
									</flowline>
									<flowline />
								</command>
								<command class_type='calculation' title='Convert raw counts to millivolts using configured reference' >
									<exp exp='Adc1mV = Adc1Raw * AdcReferencemV / AdcMaxCounts' />
								</command>
								<command class_type='calculation' title='Store ADC telemetry in low/high byte registers' >
									<exp exp='RegAdc1Raw_L = Adc1Raw &amp; 255' />
									<exp exp='RegAdc1Raw_H = Adc1Raw &gt;&gt; 8' />
									<exp exp='RegAdc1mV_L = Adc1mV &amp; 255' />
									<exp exp='RegAdc1mV_H = Adc1mV &gt;&gt; 8' />
								</command>
							</flowline>
							<flowline >
								<command class_type='call' title='Read ADC0 raw value (0-4095)' component='ADC0' macro='GetInt' >
									<return exp='Adc0Raw' />
								</command>
								<command class_type='decision' title='Clamp ADC0 raw to max count' exp='Adc0Raw &gt; AdcMaxCounts' swap='0' >
									<flowline >
										<command class_type='calculation' title='Force ADC0 raw into valid range' >
											<exp exp='Adc0Raw = AdcMaxCounts' />
										</command>
									</flowline>
									<flowline />
								</command>
								<command class_type='calculation' title='Convert raw counts to millivolts using configured reference' >
									<exp exp='Adc0mV = Adc0Raw * AdcReferencemV / AdcMaxCounts' />
								</command>
								<command class_type='calculation' title='Store ADC telemetry in low/high byte registers' >
									<exp exp='RegAdc0Raw_L = Adc0Raw &amp; 255' />
									<exp exp='RegAdc0Raw_H = Adc0Raw &gt;&gt; 8' />
									<exp exp='RegAdc0mV_L = Adc0mV &amp; 255' />
									<exp exp='RegAdc0mV_H = Adc0mV &gt;&gt; 8' />
								</command>
							</flowline>
						</command>
						<command class_type='calculation' title='Move to next channel' >
							<exp exp='AdcChannel = AdcChannel + 1' />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='ProcessCommsByte' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<local name='rx' type='u8' description='' isconst='0' isHidden='0' isinit='1' usrinit='0' setinit='0' />
						<command class_type='call' title='Get next received byte from circular buffer' component='CircularBuffer1' macro='GetByte' >
							<return exp='.rx' />
						</command>
						<command class_type='decision' title='Parser state 0: wait for header byte 1 (0xFF)' exp='ParserState = 0' swap='0' >
							<flowline >
								<command class_type='decision' title='Byte equals header value' exp='.rx = STS_HEADER' swap='0' >
									<flowline >
										<command class_type='calculation' title='Move to parser state 1 (wait for second header byte)' >
											<exp exp='ParserState = 1' />
										</command>
									</flowline>
									<flowline />
								</command>
							</flowline>
							<flowline >
								<command class_type='decision' title='Parser state 1: wait for header byte 2 (0xFF)' exp='ParserState = 1' swap='0' >
									<flowline >
										<command class_type='decision' title='Second header matched' exp='.rx = STS_HEADER' swap='0' >
											<flowline >
												<command class_type='calculation' title='Move to parser state 2 (read packet ID)' >
													<exp exp='ParserState = 2' />
												</command>
											</flowline>
											<flowline >
												<command class_type='calculation' title='Header mismatch: reset parser (or restart if new header)' >
													<exp exp='ParserState = 0' />
												</command>
												<command class_type='decision' title='If this byte is 0xFF, treat as possible first header' exp='.rx = STS_HEADER' swap='0' >
													<flowline >
														<command class_type='calculation' title='Restart at state 1' >
															<exp exp='ParserState = 1' />
														</command>
													</flowline>
													<flowline />
												</command>
											</flowline>
										</command>
									</flowline>
									<flowline >
										<command class_type='decision' title='Parser state 2: read packet ID' exp='ParserState = 2' swap='0' >
											<flowline >
												<command class_type='calculation' title='Store packet ID and start checksum sum' >
													<exp exp='PacketID = .rx' />
													<exp exp='PacketChecksumCalc = .rx' />
													<exp exp='ParserState = 3' />
												</command>
											</flowline>
											<flowline >
												<command class_type='decision' title='Parser state 3: read packet LENGTH' exp='ParserState = 3' swap='0' >
													<flowline >
														<command class_type='calculation' title='Store LENGTH and compute expected parameter count' >
															<exp exp='PacketLength = .rx' />
															<exp exp='PacketChecksumCalc = PacketChecksumCalc + .rx' />
															<exp exp='PacketParamCount = PacketLength - 2' />
															<exp exp='PacketParamIndex = 0' />
															<exp exp='ParserState = 4' />
														</command>
													</flowline>
													<flowline >
														<command class_type='decision' title='Parser state 4: read instruction byte' exp='ParserState = 4' swap='0' >
															<flowline >
																<command class_type='calculation' title='Store instruction and update checksum sum' >
																	<exp exp='PacketInstruction = .rx' />
																	<exp exp='PacketChecksumCalc = PacketChecksumCalc + .rx' />
																</command>
																<command class_type='decision' title='If there are parameters, move to state 5, else read checksum in state 6' exp='PacketParamCount &gt; 0' swap='0' >
																	<flowline >
																		<command class_type='calculation' title='Go to parameter parsing state' >
																			<exp exp='ParserState = 5' />
																		</command>
																	</flowline>
																	<flowline >
																		<command class_type='calculation' title='No parameters, go to checksum state' >
																			<exp exp='ParserState = 6' />
																		</command>
																	</flowline>
																</command>
															</flowline>
															<flowline >
																<command class_type='decision' title='Parser state 5: read parameter bytes' exp='ParserState = 5' swap='0' >
																	<flowline >
																		<command class_type='decision' title='Protect parameter buffer against overflow' exp='PacketParamIndex &lt; 32' swap='0' >
																			<flowline >
																				<command class_type='calculation' title='Store parameter byte' >
																					<exp exp='PacketBuffer[PacketParamIndex] = .rx' />
																				</command>
																			</flowline>
																			<flowline />
																		</command>
																		<command class_type='calculation' title='Update checksum and parameter index' >
																			<exp exp='PacketChecksumCalc = PacketChecksumCalc + .rx' />
																			<exp exp='PacketParamIndex = PacketParamIndex + 1' />
																		</command>
																		<command class_type='decision' title='All parameters received' exp='PacketParamIndex &gt;= PacketParamCount' swap='0' >
																			<flowline >
																				<command class_type='calculation' title='Move to checksum state' >
																					<exp exp='ParserState = 6' />
																				</command>
																			</flowline>
																			<flowline />
																		</command>
																	</flowline>
																	<flowline >
																		<command class_type='decision' title='Parser state 6: read and validate checksum' exp='ParserState = 6' swap='0' >
																			<flowline >
																				<command class_type='calculation' title='Store received checksum' >
																					<exp exp='PacketChecksumRx = .rx' />
																				</command>
																				<command class_type='calculation' title='Calculate expected checksum (~sum &amp; 0xFF)' >
																					<exp exp='PacketChecksumCalc = ~PacketChecksumCalc' />
																					<exp exp='PacketChecksumCalc = PacketChecksumCalc &amp; 255' />
																				</command>
																				<command class_type='decision' title='Valid checksum and packet addressed to this node' exp='(PacketChecksumRx = PacketChecksumCalc) &amp;&amp; (PacketID = BusDeviceID)' swap='0' >
																					<flowline >
																						<command class_type='calculation' title='Track valid packet and basic decoded fields' >
																							<exp exp='PacketValidCount = PacketValidCount + 1' />
																							<exp exp='LastInstruction = PacketInstruction' />
																							<exp exp='ResponseSent = 0' />
																						</command>
																						<command class_type='decision' title='Handle READ instruction (2)' exp='(PacketInstruction = 2) &amp;&amp; (PacketParamCount &gt;= 2)' swap='0' >
																							<flowline >
																								<command class_type='calculation' title='Store READ address and requested length' >
																									<exp exp='LastAddress = PacketBuffer[0]' />
																									<exp exp='LastDataLength = PacketBuffer[1]' />
																								</command>
																								<command class_type='decision' title='Verbose debug READ command' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 2)' swap='0' >
																									<flowline >
																										<command class_type='call' title='Debug READ prefix' component='UART_ProgDebug' macro='SendString' >
																											<argument exp='&quot;DBG cmd READ addr=&quot;' />
																										</command>
																										<command class_type='call' title='Debug READ address' component='UART_ProgDebug' macro='SendNumber' >
																											<argument exp='LastAddress' />
																										</command>
																										<command class_type='call' title='Debug READ len prefix' component='UART_ProgDebug' macro='SendString' >
																											<argument exp='&quot; len=&quot;' />
																										</command>
																										<command class_type='call' title='Debug READ length' component='UART_ProgDebug' macro='SendNumber' >
																											<argument exp='LastDataLength' />
																										</command>
																										<command class_type='call' title='Debug line ending' component='UART_ProgDebug' macro='SendString' >
																											<argument exp='&quot;\r\n&quot;' />
																										</command>
																									</flowline>
																									<flowline />
																								</command>
																								<command class_type='decision' title='Single-byte READ' exp='LastDataLength = 1' swap='0' >
																									<flowline >
																										<command class_type='call' title='Map address to a register byte' macro='ReadRegisterIntoReadValue' />
																										<command class_type='calculation' title='Send READ status packet with one data byte' >
																											<exp exp='TxLength = 3' />
																											<exp exp='TxError = 0' />
																											<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError + ReadValue' />
																											<exp exp='TxChecksumSum = ~TxChecksumSum' />
																											<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																										</command>
																										<command class_type='calculation' title='Set helper TX data byte from read value' >
																											<exp exp='TxDataByte = ReadValue' />
																										</command>
																										<command class_type='call' title='Send status packet with one data byte' macro='SendStatusPacketWithData' />
																									</flowline>
																									<flowline >
																										<command class_type='decision' title='Multi-byte READ (2 to 8 bytes)' exp='(LastDataLength &gt;= 2) &amp;&amp; (LastDataLength &lt;= 8)' swap='0' >
																											<flowline >
																												<command class_type='call' title='Send READ response with multiple register bytes' macro='SendStatusPacketWithMultiReadData' />
																											</flowline>
																											<flowline >
																												<command class_type='calculation' title='Unsupported READ length: send error status packet' >
																													<exp exp='TxLength = 2' />
																													<exp exp='TxError = 2' />
																													<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
																													<exp exp='TxChecksumSum = ~TxChecksumSum' />
																													<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																												</command>
																												<command class_type='call' title='Send status packet without data byte' macro='SendStatusPacketNoData' />
																											</flowline>
																										</command>
																									</flowline>
																								</command>
																							</flowline>
																							<flowline >
																								<command class_type='decision' title='Handle WRITE instruction (3)' exp='(PacketInstruction = 3) &amp;&amp; (PacketParamCount &gt;= 1)' swap='0' >
																									<flowline >
																										<command class_type='calculation' title='Store WRITE address and data length' >
																											<exp exp='LastAddress = PacketBuffer[0]' />
																											<exp exp='LastDataLength = PacketParamCount - 1' />
																										</command>
																										<command class_type='decision' title='Verbose debug WRITE command' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 2)' swap='0' >
																											<flowline >
																												<command class_type='call' title='Debug WRITE prefix' component='UART_ProgDebug' macro='SendString' >
																													<argument exp='&quot;DBG cmd WRITE addr=&quot;' />
																												</command>
																												<command class_type='call' title='Debug WRITE address' component='UART_ProgDebug' macro='SendNumber' >
																													<argument exp='LastAddress' />
																												</command>
																												<command class_type='call' title='Debug WRITE len prefix' component='UART_ProgDebug' macro='SendString' >
																													<argument exp='&quot; len=&quot;' />
																												</command>
																												<command class_type='call' title='Debug WRITE length' component='UART_ProgDebug' macro='SendNumber' >
																													<argument exp='LastDataLength' />
																												</command>
																												<command class_type='call' title='Debug line ending' component='UART_ProgDebug' macro='SendString' >
																													<argument exp='&quot;\r\n&quot;' />
																												</command>
																											</flowline>
																											<flowline />
																										</command>
																										<command class_type='decision' title='WRITE needs at least one data byte in this basic version' exp='PacketParamCount &gt;= 2' swap='0' >
																											<flowline >
																												<command class_type='decision' title='Writable register address (PWM 3-7 or hobby servo 48-54)' exp='((LastAddress &gt;= 3) &amp;&amp; (LastAddress &lt;= 7)) || ((LastAddress &gt;= 48) &amp;&amp; (LastAddress &lt;= 54))' swap='0' >
																													<flowline >
																														<command class_type='call' title='Copy all WRITE data bytes into register array' macro='WritePacketBytesToRegisters' />
																														<command class_type='calculation' title='Prepare WRITE acknowledge (send before slow hardware apply)' >
																															<exp exp='TxLength = 2' />
																															<exp exp='TxError = 0' />
																															<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
																															<exp exp='TxChecksumSum = ~TxChecksumSum' />
																															<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																														</command>
																														<command class_type='call' title='Send WRITE acknowledge immediately' macro='SendStatusPacketNoData' />
																														<command class_type='calculation' title='Mark reply sent so end handler does not send twice' >
																															<exp exp='ResponseSent = 1' />
																														</command>
																														<command class_type='call' title='Apply writable register values to variables and hardware' macro='ApplyWritableRegistersToVariablesAndHardware' />
																														<command class_type='decision' title='Verbose debug WRITE applied values' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 2)' swap='0' >
																															<flowline >
																																<command class_type='call' title='Debug WRITE applied prefix' component='UART_ProgDebug' macro='SendString' >
																																	<argument exp='&quot;DBG write applied pwm1=&quot;' />
																																</command>
																																<command class_type='call' title='Debug PWM1 duty value' component='UART_ProgDebug' macro='SendNumber' >
																																	<argument exp='RegPwm1Duty' />
																																</command>
																																<command class_type='call' title='Debug PWM2 prefix' component='UART_ProgDebug' macro='SendString' >
																																	<argument exp='&quot; pwm2=&quot;' />
																																</command>
																																<command class_type='call' title='Debug PWM2 duty value' component='UART_ProgDebug' macro='SendNumber' >
																																	<argument exp='RegPwm2Duty' />
																																</command>
																																<command class_type='call' title='Debug control prefix' component='UART_ProgDebug' macro='SendString' >
																																	<argument exp='&quot; ctrl=&quot;' />
																																</command>
																																<command class_type='call' title='Debug PWM control value' component='UART_ProgDebug' macro='SendNumber' >
																																	<argument exp='RegPwmControl' />
																																</command>
																																<command class_type='call' title='Debug line ending' component='UART_ProgDebug' macro='SendString' >
																																	<argument exp='&quot;\r\n&quot;' />
																																</command>
																															</flowline>
																															<flowline />
																														</command>
																													</flowline>
																													<flowline >
																														<command class_type='calculation' title='WRITE to read-only or invalid address: error status' >
																															<exp exp='TxLength = 2' />
																															<exp exp='TxError = 2' />
																															<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
																															<exp exp='TxChecksumSum = ~TxChecksumSum' />
																															<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																														</command>
																													</flowline>
																												</command>
																											</flowline>
																											<flowline >
																												<command class_type='calculation' title='WRITE missing data: send error status packet' >
																													<exp exp='TxLength = 2' />
																													<exp exp='TxError = 2' />
																													<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
																													<exp exp='TxChecksumSum = ~TxChecksumSum' />
																													<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																												</command>
																											</flowline>
																										</command>
																									</flowline>
																									<flowline >
																										<command class_type='decision' title='Handle PING instruction (1)' exp='PacketInstruction = 1' swap='0' >
																											<flowline >
																												<command class_type='calculation' title='PING has no address/data fields and sends status response' >
																													<exp exp='LastAddress = 0' />
																													<exp exp='LastDataLength = 0' />
																													<exp exp='TxLength = 2' />
																													<exp exp='TxError = 0' />
																													<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
																													<exp exp='TxChecksumSum = ~TxChecksumSum' />
																													<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																												</command>
																												<command class_type='decision' title='Verbose debug PING command' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 2)' swap='0' >
																													<flowline >
																														<command class_type='call' title='Debug PING message' component='UART_ProgDebug' macro='SendString' >
																															<argument exp='&quot;DBG cmd PING\r\n&quot;' />
																														</command>
																													</flowline>
																													<flowline />
																												</command>
																											</flowline>
																											<flowline >
																												<command class_type='calculation' title='Unsupported instruction: send error status packet' >
																													<exp exp='TxLength = 2' />
																													<exp exp='TxError = 2' />
																													<exp exp='TxChecksumSum = BusDeviceID + TxLength + TxError' />
																													<exp exp='TxChecksumSum = ~TxChecksumSum' />
																													<exp exp='TxChecksumSum = TxChecksumSum &amp; 255' />
																												</command>
																												<command class_type='decision' title='Verbose debug unknown command' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 2)' swap='0' >
																													<flowline >
																														<command class_type='call' title='Debug unknown prefix' component='UART_ProgDebug' macro='SendString' >
																															<argument exp='&quot;DBG cmd UNKNOWN inst=&quot;' />
																														</command>
																														<command class_type='call' title='Debug unknown instruction value' component='UART_ProgDebug' macro='SendNumber' >
																															<argument exp='PacketInstruction' />
																														</command>
																														<command class_type='call' title='Debug line ending' component='UART_ProgDebug' macro='SendString' >
																															<argument exp='&quot;\r\n&quot;' />
																														</command>
																													</flowline>
																													<flowline />
																												</command>
																											</flowline>
																										</command>
																									</flowline>
																								</command>
																								<command class_type='decision' title='Send status reply if not already sent (WRITE sends early)' exp='ResponseSent = 0' swap='0' >
																									<flowline >
																										<command class_type='call' title='Send status packet without data byte' macro='SendStatusPacketNoData' />
																									</flowline>
																									<flowline />
																								</command>
																							</flowline>
																						</command>
																					</flowline>
																					<flowline >
																						<command class_type='calculation' title='Invalid packet for this node or checksum mismatch' >
																							<exp exp='PacketErrorCount = PacketErrorCount + 1' />
																						</command>
																						<command class_type='decision' title='Debug invalid packet notice enabled' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 1)' swap='0' >
																							<flowline >
																								<command class_type='call' title='Debug invalid packet message' component='UART_ProgDebug' macro='SendString' >
																									<argument exp='&quot;DBG invalid packet\r\n&quot;' />
																								</command>
																							</flowline>
																							<flowline />
																						</command>
																					</flowline>
																				</command>
																				<command class_type='calculation' title='Reset parser for next packet' >
																					<exp exp='ParserState = 0' />
																				</command>
																			</flowline>
																			<flowline />
																		</command>
																	</flowline>
																</command>
															</flowline>
														</command>
													</flowline>
												</command>
											</flowline>
										</command>
									</flowline>
								</command>
							</flowline>
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='UpdateCurrentMeasurements' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='comment' title='' comment='Refresh ADS1220 current measurements each loop' textarea='12,0,12,0' />
						<command class_type='switch' title='Switch' textarea='36,25,36,25' exp='CurrentChannel' >
							<case >
								<flowline >
									<command class_type='call' title='Read PWM1 shunt voltage (AN0 single ended)' component='ADS1220' macro='SampleSglRaw' >
										<return exp='Shunt1Volts' />
										<argument exp='0' />
										<argument exp='AdcGainSetting' />
									</command>
									<command class_type='calculation' title='Convert shunt volts to current in amps (I=V/R)' >
										<exp exp='Current1A = Shunt1Volts / ShuntResistanceOhms' />
										<exp exp='Current1A = Current1A * CurrentCalibrationGain' />
									</command>
									<command class_type='decision' title='Clamp PWM1 current lower bound to 0A' exp='Current1A &lt; 0' swap='0' >
										<flowline >
											<command class_type='calculation' title='Set PWM1 current to 0A if negative' >
												<exp exp='Current1A = 0' />
											</command>
										</flowline>
										<flowline />
									</command>
									<command class_type='calculation' title='Convert amps to milliamps' >
										<exp exp='Current1mA = FLOAT (Current1A * 1000.0)' />
									</command>
									<command class_type='decision' title='Clamp PWM1 current upper bound to 2000mA (2A)' exp='Current1mA &gt; 2000' swap='0' >
										<flowline >
											<command class_type='calculation' title='Set PWM1 current to 2000mA if above range' >
												<exp exp='Current1mA = 2000' />
											</command>
										</flowline>
										<flowline />
									</command>
									<command class_type='calculation' title='Store milliamps in low/high byte register pairs' >
										<exp exp='RegCurrent1mA_L = Current1mA &amp; 255' />
										<exp exp='RegCurrent1mA_H = Current1mA &gt;&gt; 8' />
									</command>
								</flowline>
							</case>
							<case exp='1' >
								<flowline >
									<command class_type='call' title='Read PWM2 shunt voltage (AN1 single ended)' component='ADS1220' macro='SampleSglVolts' >
										<return exp='Shunt2Volts' />
										<argument exp='1' />
										<argument exp='AdcGainSetting' />
									</command>
									<command class_type='calculation' title='Convert shunt volts to current in amps (I=V/R)' >
										<exp exp='Current2A = Shunt2Volts / ShuntResistanceOhms' />
										<exp exp='Current2A = Current2A * CurrentCalibrationGain' />
									</command>
									<command class_type='decision' title='Clamp PWM2 current lower bound to 0A' exp='Current2A &lt; 0' swap='0' >
										<flowline >
											<command class_type='calculation' title='Set PWM2 current to 0A if negative' >
												<exp exp='Current2A = 0' />
											</command>
										</flowline>
										<flowline />
									</command>
									<command class_type='calculation' title='Convert amps to milliamps' >
										<exp exp='Current2mA = FLOAT (Current2A * 1000.0)' />
									</command>
									<command class_type='decision' title='Clamp PWM2 current upper bound to 2000mA (2A)' exp='Current2mA &gt; 2000' swap='0' >
										<flowline >
											<command class_type='calculation' title='Set PWM2 current to 2000mA if above range' >
												<exp exp='Current2mA = 2000' />
											</command>
										</flowline>
										<flowline />
									</command>
									<command class_type='calculation' title='Store milliamps in low/high byte register pairs' >
										<exp exp='RegCurrent2mA_L = Current2mA &amp; 255' />
										<exp exp='RegCurrent2mA_H = Current2mA &gt;&gt; 8' />
									</command>
								</flowline>
							</case>
							<case exp='2' >
								<flowline >
									<command class_type='call' title='Read Servo shunt voltage (AN2 single ended)' component='ADS1220' macro='SampleSglVolts' >
										<return exp='Shunt3Volts' />
										<argument exp='2' />
										<argument exp='AdcGainSetting' />
									</command>
									<command class_type='calculation' title='Convert shunt volts to current in amps (I=V/R)' >
										<exp exp='Current3A = Shunt3Volts / ShuntResistanceOhms' />
										<exp exp='Current3A = Current3A * CurrentCalibrationGain' />
									</command>
									<command class_type='decision' title='Clamp Servo current lower bound to 0A' exp='Current3A &lt; 0' swap='0' >
										<flowline >
											<command class_type='calculation' title='Set Servo current to 0A if negative' >
												<exp exp='Current3A = 0' />
											</command>
										</flowline>
										<flowline />
									</command>
									<command class_type='calculation' title='Convert amps to milliamps' >
										<exp exp='Current3mA = FLOAT (Current3A * 1000.0)' />
									</command>
									<command class_type='decision' title='Clamp Servo current upper bound to 2000mA (2A)' exp='Current3mA &gt; 2000' swap='0' >
										<flowline >
											<command class_type='calculation' title='Set Servo current to 2000mA if above range' >
												<exp exp='Current3mA = 2000' />
											</command>
										</flowline>
										<flowline />
									</command>
									<command class_type='calculation' title='Store milliamps in low/high byte register pairs' >
										<exp exp='RegCurrent3mA_L = Current3mA &amp; 255' />
										<exp exp='RegCurrent3mA_H = Current3mA &gt;&gt; 8' />
									</command>
								</flowline>
							</case>
						</command>
						<command class_type='calculation' title='Move to next channel' >
							<exp exp='CurrentChannel = CurrentChannel + 1' />
						</command>
						<command class_type='decision' title='Decision' exp='CurrentChannel &gt;= 3' swap='0' >
							<flowline >
								<command class_type='calculation' title='Move to next channel' >
									<exp exp='CurrentChannel = 0' />
								</command>
							</flowline>
							<flowline />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='ServoBus_RX' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<local name='rx' type='u8' description='' isconst='0' isHidden='0' isinit='1' usrinit='0' setinit='0' />
						<command class_type='call' title='Read byte from Serial servo bus' component='UART_ServoBus' macro='ReceiveChar' >
							<return exp='.rx' />
							<argument exp='0' />
						</command>
						<command class_type='call' title='Add byte to circular buffer for processing' component='CircularBuffer1' macro='PutByte' >
							<argument exp='.rx' />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='SendStatusPacketNoData' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='call' title='TX Header 1' component='UART_ServoBus' macro='SendChar' >
							<argument exp='255' />
						</command>
						<command class_type='call' title='TX Header 2' component='UART_ServoBus' macro='SendChar' >
							<argument exp='255' />
						</command>
						<command class_type='call' title='TX ID' component='UART_ServoBus' macro='SendChar' >
							<argument exp='BusDeviceID' />
						</command>
						<command class_type='call' title='TX LENGTH' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxLength' />
						</command>
						<command class_type='call' title='TX ERROR' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxError' />
						</command>
						<command class_type='call' title='TX CHECKSUM' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxChecksumSum' />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='SendStatusPacketWithData' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='call' title='TX Header 1' component='UART_ServoBus' macro='SendChar' >
							<argument exp='255' />
						</command>
						<command class_type='call' title='TX Header 2' component='UART_ServoBus' macro='SendChar' >
							<argument exp='255' />
						</command>
						<command class_type='call' title='TX ID' component='UART_ServoBus' macro='SendChar' >
							<argument exp='BusDeviceID' />
						</command>
						<command class_type='call' title='TX LENGTH' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxLength' />
						</command>
						<command class_type='call' title='TX ERROR' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxError' />
						</command>
						<command class_type='call' title='TX DATA BYTE' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxDataByte' />
						</command>
						<command class_type='call' title='TX CHECKSUM' component='UART_ServoBus' macro='SendChar' >
							<argument exp='TxChecksumSum' />
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='WritePacketBytesToRegisters' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='calculation' title='Start at first data byte in packet buffer' >
							<exp exp='CommsByteIndex = 0' />
						</command>
						<command class_type='loop' title='Copy each WRITE data byte into Registers[]' type='0' exp='CommsByteIndex &lt; LastDataLength' for1='' for2='' for3='' >
							<flowline >
								<command class_type='decision' title='Destination address is inside register map' exp='(LastAddress + CommsByteIndex) &lt; 64' swap='0' >
									<flowline >
										<command class_type='calculation' title='Write one byte from packet to register array' >
											<exp exp='Registers[LastAddress + CommsByteIndex] = PacketBuffer[1 + CommsByteIndex]' />
										</command>
									</flowline>
									<flowline />
								</command>
								<command class_type='calculation' title='Next byte' >
									<exp exp='CommsByteIndex = CommsByteIndex + 1' />
								</command>
							</flowline>
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='ApplyWritableRegistersToVariablesAndHardware' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='calculation' title='Apply writable register bytes to named variables' >
							<exp exp='RegToolTypeId = Registers[3]' />
							<exp exp='RegStatusFlags = Registers[4]' />
							<exp exp='RegPwm1Duty = Registers[5]' />
							<exp exp='RegPwm2Duty = Registers[6]' />
							<exp exp='RegPwmControl = Registers[7]' />
						</command>
						<command class_type='comment' title='' comment='Apply PWM1 register values to hardware output' textarea='12,0,12,0' />
						<command class_type='decision' title='PWM1 enabled bit is set' exp='(RegPwmControl &amp; 1) &gt; 0' swap='0' >
							<flowline >
								<command class_type='call' title='Enable PWM1 output' component='PWM1' macro='Enable' />
								<command class_type='call' title='Apply PWM1 duty cycle' component='PWM1' macro='SetDutyCycle' >
									<argument exp='RegPwm1Duty' />
								</command>
							</flowline>
							<flowline >
								<command class_type='call' title='Disable PWM1 output' component='PWM1' macro='Disable' />
							</flowline>
						</command>
						<command class_type='comment' title='' comment='Apply PWM2 register values to hardware output' textarea='12,0,12,0' />
						<command class_type='decision' title='PWM2 enabled bit is set' exp='(RegPwmControl &amp; 2) &gt; 0' swap='0' >
							<flowline >
								<command class_type='call' title='Enable PWM2 output' component='PWM2' macro='Enable' />
								<command class_type='call' title='Apply PWM2 duty cycle' component='PWM2' macro='SetDutyCycle' >
									<argument exp='RegPwm2Duty' />
								</command>
							</flowline>
							<flowline >
								<command class_type='call' title='Disable PWM2 output' component='PWM2' macro='Disable' />
							</flowline>
						</command>
						<command class_type='comment' title='' comment='Apply hobby servo registers (48+) to Servo_Controller1' textarea='12,0,12,0' />
						<command class_type='calculation' title='Load hobby servo variables from register array' >
							<exp exp='RegServoEnable = Registers[48]' />
							<exp exp='RegServoPosition8bit = Registers[49]' />
							<exp exp='RegServoAngleDeg = Registers[50]' />
							<exp exp='RegServoPulseMin_L = Registers[51]' />
							<exp exp='RegServoPulseMin_H = Registers[52]' />
							<exp exp='RegServoPulseMax_L = Registers[53]' />
							<exp exp='RegServoPulseMax_H = Registers[54]' />
						</command>
						<command class_type='decision' title='Hobby servo output enabled' exp='RegServoEnable &gt; 0' swap='0' >
							<flowline >
								<command class_type='call' title='Enable hobby servo channel' component='Servo_Controller1' macro='EnableServo' >
									<argument exp='HobbyServoChannel' />
								</command>
								<command class_type='decision' title='Last write was angle register (50)' exp='LastAddress = 50' swap='0' >
									<flowline >
										<command class_type='call' title='Move hobby servo to angle in degrees' component='Servo_Controller1' macro='MoveToAngle' >
											<argument exp='HobbyServoChannel' />
											<argument exp='RegServoAngleDeg' />
										</command>
									</flowline>
									<flowline >
										<command class_type='decision' title='Last write was position register (49)' exp='LastAddress = 49' swap='0' >
											<flowline >
												<command class_type='call' title='Move hobby servo to 8-bit position' component='Servo_Controller1' macro='SetPosition' >
													<argument exp='HobbyServoChannel' />
													<argument exp='RegServoPosition8bit' />
												</command>
											</flowline>
											<flowline >
												<command class_type='call' title='Default: apply current angle when enable-only write' component='Servo_Controller1' macro='MoveToAngle' >
													<argument exp='HobbyServoChannel' />
													<argument exp='RegServoAngleDeg' />
												</command>
											</flowline>
										</command>
									</flowline>
								</command>
							</flowline>
							<flowline >
								<command class_type='call' title='Disable hobby servo channel' component='Servo_Controller1' macro='DisableServo' >
									<argument exp='HobbyServoChannel' />
								</command>
							</flowline>
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='Main' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='call' title='Component Macro' component='UART_ServoBus' macro='Initialise' />
						<command class_type='call' title='Component Macro' component='UART_ProgDebug' macro='Initialise' />
						<command class_type='call' title='Component Macro' component='ADS1220' macro='Initialise' />
						<command class_type='call' title='Component Macro' component='Servo_Controller1' macro='Initialise' />
						<command class_type='decision' title='Debug enabled at startup' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 1)' swap='0' >
							<flowline >
								<command class_type='call' title='Debug boot banner' component='UART_ProgDebug' macro='SendString' >
									<argument exp='&quot;DBG boot\r\n&quot;' />
								</command>
							</flowline>
							<flowline />
						</command>
						<command class_type='comment' title='' comment='Start with PWM outputs disabled and duty set to 0' textarea='12,0,12,0' />
						<command class_type='call' title='Set PWM1 duty to initial register value' component='PWM1' macro='SetDutyCycle' >
							<argument exp='RegPwm1Duty' />
						</command>
						<command class_type='call' title='Set PWM2 duty to initial register value' component='PWM2' macro='SetDutyCycle' >
							<argument exp='RegPwm2Duty' />
						</command>
						<command class_type='call' title='Disable PWM1 at startup' component='PWM1' macro='Disable' />
						<command class_type='call' title='Disable PWM2 at startup' component='PWM2' macro='Disable' />
						<command class_type='call' title='Disable hobby servo output at startup' component='Servo_Controller1' macro='DisableServo' >
							<argument exp='HobbyServoChannel' />
						</command>
						<command class_type='interrupt' title='Interrupt on Servo Bus Enable' enable='1' name='RXINT1' call='ServoBus_RX' >
							<settings timer='0' prescale='-1' postscale='-1' rollover='-1' bitcount='-1' trigger='3' ppsport='-1' ppspin='-1' maskhi='--------------------------------------------------------------------------------------------------------------------------------------------------------------------------8' masklo='--------------------------------------------------------------------------------------------------------------------------------------------------------------------------8' >
								<option value='0' />
								<option value='0' />
								<option value='0' />
								<option value='0' />
								<option value='0' />
								<option value='0' />
								<option value='0' />
								<option value='0' />
							</settings>
						</command>
						<command class_type='comment' title='' comment='Main program loop' textarea='12,0,12,0' />
						<command class_type='loop' title='Loop' type='3' exp='1' for1='' for2='' for3='' >
							<flowline >
								<command class_type='decision' title='Decision' exp='LoopCounter = 5' swap='0' >
									<flowline >
										<command class_type='call' title='Update ADS1220-based current registers' macro='UpdateCurrentMeasurements' />
									</flowline>
									<flowline />
								</command>
								<command class_type='decision' title='Decision' exp='LoopCounter = 10' swap='0' >
									<flowline >
										<command class_type='call' title='Update ADC0/ADC1 telemetry registers' macro='UpdateAdcTelemetry' />
										<command class_type='calculation' title='Calculation' >
											<exp exp='LoopCounter = 0' />
										</command>
									</flowline>
									<flowline >
										<command class_type='calculation' title='Calculation' >
											<exp exp='LoopCounter++' />
										</command>
									</flowline>
								</command>
								<command class_type='call' title='Refresh register array from named variables' macro='RefreshRegisterArrayFromVariables' />
								<command class_type='decision' title='Debug periodic status output enabled' exp='(DebugEnabled = 1) &amp;&amp; (DebugLevel &gt;= 1)' swap='0' >
									<flowline >
										<command class_type='calculation' title='Increment debug counter' >
											<exp exp='DebugCounter++' />
										</command>
										<command class_type='decision' title='Every 100 loops send system status' exp='DebugCounter &gt;= 100' swap='0' >
											<flowline >
												<command class_type='calculation' title='Reset debug counter' >
													<exp exp='DebugCounter = 0' />
												</command>
												<command class_type='call' title='Debug status prefix' component='UART_ProgDebug' macro='SendString' >
													<argument exp='&quot;DBG ok valid=&quot;' />
												</command>
												<command class_type='call' title='Debug valid packet count' component='UART_ProgDebug' macro='SendNumber' >
													<argument exp='PacketValidCount' />
												</command>
												<command class_type='call' title='Debug error separator' component='UART_ProgDebug' macro='SendString' >
													<argument exp='&quot; err=&quot;' />
												</command>
												<command class_type='call' title='Debug error count' component='UART_ProgDebug' macro='SendNumber' >
													<argument exp='PacketErrorCount' />
												</command>
												<command class_type='call' title='Debug line ending' component='UART_ProgDebug' macro='SendString' >
													<argument exp='&quot;\r\n&quot;' />
												</command>
											</flowline>
											<flowline />
										</command>
									</flowline>
									<flowline />
								</command>
								<command class_type='loop' title='Process all bytes currently waiting in circular buffer' type='0' exp='CircularBuffer1::GetNumberBytes() &gt; 0' for1='' for2='' for3='' >
									<flowline >
										<command class_type='call' title='User Macro' macro='ProcessCommsByte' />
									</flowline>
								</command>
								<command class_type='delay' title='Delay to keep watchdog timer happy' exp='10' type='1' />
							</flowline>
						</command>
					</flowline>
				</macro>
				<macro >
					<flowline name='ReadRegisterIntoReadValue' description='' statediag='0' >
						<return name='Return' type='v0' description='' isconst='0' isHidden='0' isinit='0' usrinit='' setinit='' />
						<command class_type='decision' title='Read address is inside register array range' exp='LastAddress &lt; 64' swap='0' >
							<flowline >
								<command class_type='calculation' title='Read byte directly from register array' >
									<exp exp='ReadValue = Registers[LastAddress]' />
								</command>
							</flowline>
							<flowline >
								<command class_type='calculation' title='Out-of-range addresses return zero' >
									<exp exp='ReadValue = 0' />
								</command>
							</flowline>
						</command>
					</flowline>
				</macro>
			</macros>
